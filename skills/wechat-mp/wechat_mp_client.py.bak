    """获取最新文章的数据统计（阅读、点赞等）"""
    _ensure_logged_in()

    run_ab(f"open {MP_URL}/cgi-bin/appmsganalysis?sub=list", timeout=15)
    time.sleep(3)
    run_ab("wait --load networkidle", timeout=15)

    snap = run_ab("snapshot -i --json")
    snap_str = json.dumps(snap, ensure_ascii=False) if isinstance(snap, dict) else str(snap)

    stats_screenshot = os.path.expanduser("~/.openclaw/workspace/data/wechat-mp-stats.png")
    run_ab(f"screenshot --full {stats_screenshot}", timeout=10)

