        "screenshot": stats_screenshot
    }, ensure_ascii=False))


def create_draft(params_json):
    """创建文章草稿"""
    _ensure_logged_in()

    try:
        params = json.loads(params_json)
    except json.JSONDecodeError:
        print(json.dumps({"status": "error", "message": "参数格式错误，需要JSON格式"}, ensure_ascii=False))
        return

    title = params.get("title", "")
    content = params.get("content", "")

    if not title or not content:
        print(json.dumps({"status": "error", "message": "标题和内容不能为空"}, ensure_ascii=False))
        return

    run_ab(f"open {MP_URL}/cgi-bin/appmsg?t=media/appmsg_edit&action=edit&type=77", timeout=20)
    time.sleep(4)
    run_ab("wait --load networkidle", timeout=15)

    snap = run_ab("snapshot -i --json")
    refs = _extract_refs(snap)

    # 填写标题
    for ref_id, ref_info in refs.items():
        ref_str = json.dumps(ref_info, ensure_ascii=False).lower()
        if "标题" in ref_str or "title" in ref_str:
            run_ab(f'fill @{ref_id} "{title}"')
            break

    time.sleep(1)

    # 尝试点击正文区域并输入
    for ref_id, ref_info in refs.items():
        ref_role = str(ref_info.get("role", ""))
        ref_str = json.dumps(ref_info, ensure_ascii=False).lower()
        if "正文" in ref_str or ref_role in ["textbox", "document"]:
            run_ab(f"click @{ref_id}")
            time.sleep(0.5)
            run_ab(f'type @{ref_id} "{content}"')
            break

    time.sleep(1)

    draft_screenshot = os.path.expanduser("~/.openclaw/workspace/data/wechat-mp-draft.png")
    run_ab(f"screenshot --full {draft_screenshot}", timeout=10)

    print(json.dumps({
        "status": "draft_created",
        "message": f"草稿已创建，标题: {title}",
        "screenshot": draft_screenshot,
        "next_steps": "使用 publish_confirm 命令点击发布按钮"
    }, ensure_ascii=False))


def publish_article(params_json):
    """通过微信公众号后台发布文章"""
    _ensure_logged_in()

    try:
        params = json.loads(params_json)
    except json.JSONDecodeError:
        print(json.dumps({"status": "error", "message": "参数格式错误，需要JSON格式"}, ensure_ascii=False))
        return

    title = params.get("title", "")
    content = params.get("content", "")
    author = params.get("author", "")

    if not title or not content:
        print(json.dumps({"status": "error", "message": "标题和内容不能为空"}, ensure_ascii=False))
        return

    print(json.dumps({"step": 1, "message": "正在打开文章编辑器..."}, ensure_ascii=False), flush=True)
    run_ab(f"open {MP_URL}/cgi-bin/appmsg?t=media/appmsg_edit&action=edit&type=77", timeout=20)
    time.sleep(5)
    run_ab("wait --load networkidle", timeout=15)

    snap = run_ab("snapshot -i --json")
    refs = _extract_refs(snap)

    # 填写标题
    print(json.dumps({"step": 2, "message": f"正在填写标题: {title}"}, ensure_ascii=False), flush=True)
    title_filled = False
    for ref_id, ref_info in refs.items():
        ref_str = json.dumps(ref_info, ensure_ascii=False).lower()
        if "标题" in ref_str or "title" in ref_str:
            run_ab(f'fill @{ref_id} "{title}"')
            title_filled = True
            break
    time.sleep(1)

    # 填写作者（如果有）
    if author:
        for ref_id, ref_info in refs.items():
            ref_str = json.dumps(ref_info, ensure_ascii=False).lower()
            if "作者" in ref_str or "author" in ref_str:
                run_ab(f'fill @{ref_id} "{author}"')
                break
        time.sleep(0.5)

    # 填写正文
    print(json.dumps({"step": 3, "message": "正在填写正文内容..."}, ensure_ascii=False), flush=True)
    for ref_id, ref_info in refs.items():
        ref_role = str(ref_info.get("role", ""))
        ref_str = json.dumps(ref_info, ensure_ascii=False).lower()
        if "正文" in ref_str or "编辑" in ref_str or ref_role in ["textbox", "document"]:
            run_ab(f"click @{ref_id}")
            time.sleep(0.5)
            # 分段输入长内容
            paragraphs = content.split("\\n")
            for p in paragraphs:
                if p.strip():
                    run_ab(f'type @{ref_id} "{p.strip()}"')
                    run_ab('press Enter')
                    time.sleep(0.3)
            break
    time.sleep(1)

    draft_screenshot = os.path.expanduser("~/.openclaw/workspace/data/wechat-mp-publish-draft.png")
    run_ab(f"screenshot --full {draft_screenshot}", timeout=10)
    run_ab(f"state save {STATE_FILE}")

    print(json.dumps({
        "status": "draft_ready",
        "message": f"文章草稿已准备好。标题: {title}",
        "screenshot": draft_screenshot,
        "next_steps": "确认内容无误后，使用 publish_confirm 命令发布"
    }, ensure_ascii=False))


def publish_confirm():
    """确认发布（点击发布/群发按钮）"""
    _ensure_logged_in()

    snap = run_ab("snapshot -i --json")
    refs = _extract_refs(snap)

    for ref_id, ref_info in refs.items():
        ref_str = json.dumps(ref_info, ensure_ascii=False)
        if any(kw in ref_str for kw in ["群发", "发布", "发送", "保存并群发"]):
            run_ab(f"click @{ref_id}")
            time.sleep(3)

            # 处理确认弹窗
            snap2 = run_ab("snapshot -i --json")
            refs2 = _extract_refs(snap2)
            for ref_id2, ref_info2 in refs2.items():
                ref_str2 = json.dumps(ref_info2, ensure_ascii=False)
                if "确定" in ref_str2 or "确认" in ref_str2 or "发送" in ref_str2:
                    run_ab(f"click @{ref_id2}")
                    break

            time.sleep(3)
            confirm_screenshot = os.path.expanduser("~/.openclaw/workspace/data/wechat-mp-published.png")
            run_ab(f"screenshot {confirm_screenshot}", timeout=10)

            print(json.dumps({
                "status": "published",
                "message": "文章已发布！",
                "screenshot": confirm_screenshot
            }, ensure_ascii=False))
            return

    print(json.dumps({"status": "error", "message": "未找到发布按钮，请截图查看当前页面状态"}, ensure_ascii=False))


def get_account_info():
    """获取公众号账号信息"""
    _ensure_logged_in()

    run_ab(f"open {MP_URL}/cgi-bin/settingpage?t=setting/index", timeout=15)
    time.sleep(3)
    run_ab("wait --load networkidle", timeout=15)

    snap = run_ab("snapshot -i --json")
    snap_str = json.dumps(snap, ensure_ascii=False) if isinstance(snap, dict) else str(snap)

    info_screenshot = os.path.expanduser("~/.openclaw/workspace/data/wechat-mp-account.png")
    run_ab(f"screenshot --full {info_screenshot}", timeout=10)

    print(json.dumps({
        "status": "success",
        "message": "已获取账号信息",
        "snapshot": snap_str[:5000],
        "screenshot": info_screenshot
    }, ensure_ascii=False))


def _extract_refs(snap):
    """从snapshot中提取refs"""
    refs = {}
    if isinstance(snap, dict):
        data = snap.get("data", snap)
        if isinstance(data, dict):
            refs = data.get("refs", {})
    return refs


def _ensure_logged_in():
    """确保已登录"""
    if os.path.exists(STATE_FILE):
        result = run_ab(f"state load {STATE_FILE}")
        if result.get("success"):
            return True

    run_ab(f"open {MP_URL}", timeout=15)
    time.sleep(3)
    run_ab("wait --load networkidle", timeout=10)

    url_result = run_ab("get url --json")
    current_url = str(url_result.get("data", "")) if isinstance(url_result, dict) else ""

    if "login" in current_url.lower() or "scanlogin" in current_url.lower():
        print(json.dumps({
            "status": "not_logged_in",
            "message": "未登录，请先使用 login 命令登录"
        }, ensure_ascii=False))
        sys.exit(1)

    return True


def main():
    if len(sys.argv) < 2:
        print(json.dumps({
            "usage": {
                "login": "登录微信公众号（获取二维码截图）",
                "login_confirm": "确认扫码登录（扫码后调用）",
                "status": "检查登录状态",
                "articles": "获取文章列表",
                "article_stats": "获取最新文章数据统计",
                "draft": "创建文章草稿 (需JSON参数: title, content)",
                "publish": "发布文章 (需JSON参数: title, content, author)",
                "publish_confirm": "确认发布已编辑好的文章",
                "account_info": "获取账号信息"
            }
        }, ensure_ascii=False, indent=2))
        return

    command = sys.argv[1]

    commands = {
        "login": login,
        "login_confirm": login_confirm,
        "status": check_status,
        "articles": get_articles,
        "article_stats": get_article_stats,
        "account_info": get_account_info,
        "publish_confirm": publish_confirm,
    }

    if command in commands:
        commands[command]()
    elif command == "draft":
        if len(sys.argv) < 3:
            print(json.dumps({"error": "需要JSON参数"}, ensure_ascii=False))
            return
        create_draft(sys.argv[2])
    elif command == "publish":
        if len(sys.argv) < 3:
            print(json.dumps({"error": "需要JSON参数"}, ensure_ascii=False))
            return
        publish_article(sys.argv[2])
    else:
        print(json.dumps({"error": f"未知命令: {command}"}, ensure_ascii=False))


if __name__ == "__main__":
    main()
